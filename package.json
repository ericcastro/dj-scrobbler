{
  "name": "dj-scrobbler",
  "productName": "DJ Scrobbler",
  "version": "0.4.2",
  "description": "Scrobble tracks from DJ sets on YouTube and SoundCloud",
  "author": "Eric Castro <errrick@gmail.com>",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "release": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.djscrobbler.app",
    "productName": "DJ Scrobbler",
    "copyright": "Copyright © 2025 Eric Castro",

    "directories": {
      "buildResources": "build-resources",
      "output": "dist"
    },

    "files": [
      "main.js",
      "preload.js",
      "plugins/**/*",
      "renderer/**/*",
      "fonts/**/*",
      "images/**/*",
      "!images/electron-icons/**/*.svg",
      "!images/electron-icons/**/*.iconset",
      "!**/node_modules/.cache/**",
      "!**/*.map"
    ],

    "afterPack": "./scripts/afterPack.js",

    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "icon": "images/electron-icons/neon-night/icon.icns",
      "category": "public.app-category.music",
      "darkModeSupport": true,
      "gatekeeperAssess": false,
      "identity": null
    },

    "dmg": {
      "title": "DJ Scrobbler ${version}",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },

    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "images/electron-icons/neon-night/icon.ico"
    },

    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },

    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "images/electron-icons/neon-night/png",
      "category": "Audio"
    },

    "publish": {
      "provider": "github",
      "owner": "ericcastro",
      "repo": "dj-scrobbler"
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  }
}
